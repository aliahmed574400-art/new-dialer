<UserControl x:Class="NewDialer.Desktop.Views.LoginView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/NewDialer.Desktop;component/Themes/Palette.xaml" />
      </ResourceDictionary.MergedDictionaries>
      <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </ResourceDictionary>
  </UserControl.Resources>
  <Grid Background="{StaticResource CanvasBrush}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="1.05*" />
      <ColumnDefinition Width="0.95*" />
    </Grid.ColumnDefinitions>
    <Border Grid.Column="0" Margin="28" Background="{StaticResource SidebarBrush}" CornerRadius="28" Padding="34">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
          <TextBlock Text="NEWDIALER" FontFamily="Bahnschrift SemiBold" FontSize="28" Foreground="White" />
          <TextBlock Text="Desktop outbound operations center" Margin="0,10,0,0" Foreground="#D8E3F0" FontSize="16" />
        </StackPanel>
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
          <TextBlock Text="Live Zoom Phone dialer, protected lead visibility, and subscription-aware access in one desktop workspace." Foreground="White" FontFamily="Bahnschrift SemiBold" FontSize="34" TextWrapping="Wrap" />
          <TextBlock Text="Admins can onboard a company, import leads, and manage agents. Agents get assigned leads only, without copy access, while developers can monitor trials and billing across tenants." Margin="0,18,0,0" Foreground="#D8E3F0" FontSize="15" TextWrapping="Wrap" />
          <WrapPanel Margin="0,26,0,0">
            <Border Background="#1FFFFFFF" CornerRadius="16" Padding="14" Margin="0,0,14,14">
              <StackPanel Width="170">
                <TextBlock Text="Auth" Foreground="#A7F3D0" FontWeight="SemiBold" />
                <TextBlock Text="JWT sessions with role-aware desktop access." Margin="0,8,0,0" Foreground="White" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <Border Background="#1FFFFFFF" CornerRadius="16" Padding="14" Margin="0,0,14,14">
              <StackPanel Width="170">
                <TextBlock Text="Dialing" Foreground="#FDE68A" FontWeight="SemiBold" />
                <TextBlock Text="Continuous queue mode with pause, resume, stop, and Zoom hang up." Margin="0,8,0,0" Foreground="White" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <Border Background="#1FFFFFFF" CornerRadius="16" Padding="14" Margin="0,0,14,14">
              <StackPanel Width="170">
                <TextBlock Text="Scheduling" Foreground="#BFDBFE" FontWeight="SemiBold" />
                <TextBlock Text="Persisted callbacks with timezone and notes stored in PostgreSQL." Margin="0,8,0,0" Foreground="White" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </WrapPanel>
        </StackPanel>
        <TextBlock Grid.Row="2" Text="Tip: agents should sign in with username + workspace key, while admins can use email." Foreground="#AFC0D2" FontSize="13" TextWrapping="Wrap" />
      </Grid>
    </Border>
    <Grid Grid.Column="1" Margin="20,28,28,28">
      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
        <Border Style="{StaticResource CardBorderStyle}" VerticalAlignment="Top" Padding="28">
          <StackPanel>
            <TextBlock Text="{Binding AuthenticationTitle}" FontFamily="Bahnschrift SemiBold" FontSize="30" Foreground="{StaticResource InkBrush}" />
            <TextBlock Text="{Binding AuthenticationSubtitle}" Margin="0,10,0,0" Foreground="{StaticResource MutedInkBrush}" FontSize="14" TextWrapping="Wrap" />

            <Border Margin="0,18,0,0" Padding="12" Background="#FFF0FDF9" BorderBrush="#FFBAE6D6" BorderThickness="1" CornerRadius="14" Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}">
              <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" />
            </Border>
            <Border Margin="0,12,0,0" Padding="12" Background="#FFFFF1F2" BorderBrush="#FFFECACA" BorderThickness="1" CornerRadius="14" Visibility="{Binding HasErrorMessage, Converter={StaticResource BoolToVis}}">
              <TextBlock Text="{Binding ErrorMessage}" Foreground="#FFB42318" TextWrapping="Wrap" />
            </Border>

            <StackPanel Visibility="{Binding IsLoginMode, Converter={StaticResource BoolToVis}}">
              <TextBlock Text="Email Or Username" Margin="0,20,0,8" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
              <TextBox Text="{Binding LoginIdentity, UpdateSourceTrigger=PropertyChanged}" Padding="12,10" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1" />
              <TextBlock Text="Workspace Key (required for agent usernames)" Margin="0,16,0,8" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
              <TextBox Text="{Binding LoginWorkspaceKey, UpdateSourceTrigger=PropertyChanged}" Padding="12,10" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1" />
              <TextBlock Text="Password" Margin="0,16,0,8" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
              <PasswordBox x:Name="LoginPasswordBox" Padding="12,10" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1" PasswordChanged="LoginPasswordBox_OnPasswordChanged" />
            </StackPanel>

            <StackPanel Visibility="{Binding IsSignupMode, Converter={StaticResource BoolToVis}}">
              <TextBlock Text="Full Name" Margin="0,20,0,8" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
              <TextBox Text="{Binding SignupFullName, UpdateSourceTrigger=PropertyChanged}" Padding="12,10" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1" />
              <TextBlock Text="Email" Margin="0,16,0,8" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
              <TextBox Text="{Binding SignupEmail, UpdateSourceTrigger=PropertyChanged}" Padding="12,10" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1" />
              <TextBlock Text="Company Name" Margin="0,16,0,8" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
              <TextBox Text="{Binding SignupCompanyName, UpdateSourceTrigger=PropertyChanged}" Padding="12,10" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1" />
              <TextBlock Text="Phone Number" Margin="0,16,0,8" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
              <TextBox Text="{Binding SignupPhoneNumber, UpdateSourceTrigger=PropertyChanged}" Padding="12,10" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1" />
              <TextBlock Text="Password" Margin="0,16,0,8" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
              <PasswordBox x:Name="SignupPasswordBox" Padding="12,10" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1" PasswordChanged="SignupPasswordBox_OnPasswordChanged" />
              <TextBlock Text="Confirm Password" Margin="0,16,0,8" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
              <PasswordBox x:Name="SignupConfirmPasswordBox" Padding="12,10" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1" PasswordChanged="SignupConfirmPasswordBox_OnPasswordChanged" />
            </StackPanel>

            <WrapPanel Margin="0,24,0,0">
              <Button Content="{Binding AuthenticationSubmitText}" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding AuthenticateCommand}" />
              <Button Content="{Binding AuthenticationSwitchText}" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ToggleAuthenticationModeCommand}" />
            </WrapPanel>
          </StackPanel>
        </Border>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>
