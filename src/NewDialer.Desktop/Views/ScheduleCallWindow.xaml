<Window x:Class="NewDialer.Desktop.Views.ScheduleCallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Schedule Call"
        Width="460"
        Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFF6F1E8">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/NewDialer.Desktop;component/Themes/Palette.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="20">
        <Border Style="{StaticResource CardBorderStyle}" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="LeadNameTextBlock" FontFamily="Bahnschrift SemiBold" FontSize="22" Foreground="{StaticResource InkBrush}" />
                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                    <TextBlock Text="Date" Foreground="{StaticResource MutedInkBrush}" />
                    <DatePicker x:Name="ScheduleDatePicker" Margin="0,6,0,0" />
                </StackPanel>
                <StackPanel Grid.Row="2" Margin="0,16,0,0">
                    <TextBlock Text="Time (HH:mm)" Foreground="{StaticResource MutedInkBrush}" />
                    <TextBox x:Name="TimeTextBox" Margin="0,6,0,0" Text="10:00" />
                </StackPanel>
                <StackPanel Grid.Row="3" Margin="0,16,0,0">
                    <TextBlock Text="Time Zone" Foreground="{StaticResource MutedInkBrush}" />
                    <ComboBox x:Name="TimeZoneComboBox" Margin="0,6,0,0" DisplayMemberPath="DisplayName" />
                </StackPanel>
                <StackPanel Grid.Row="4" Margin="0,16,0,0">
                    <TextBlock Text="Notes" Foreground="{StaticResource MutedInkBrush}" />
                    <TextBox x:Name="NotesTextBox" Margin="0,6,0,0" Height="100" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </StackPanel>
                <WrapPanel Grid.Row="5" Margin="0,20,0,0" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{StaticResource SecondaryButtonStyle}" Click="Cancel_Click" />
                    <Button Content="Save Schedule" Style="{StaticResource PrimaryButtonStyle}" Click="Save_Click" />
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
