<UserControl x:Class="NewDialer.Desktop.Views.MainShellView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:converters="clr-namespace:NewDialer.Desktop.Converters">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/NewDialer.Desktop;component/Themes/Palette.xaml" />
      </ResourceDictionary.MergedDictionaries>
      <BooleanToVisibilityConverter x:Key="BoolToVis" />
      <converters:SectionToVisibilityConverter x:Key="SectionToVisibilityConverter" />
      <DataTemplate x:Key="NavItemTemplate">
        <StackPanel>
          <TextBlock Text="{Binding Title}" FontFamily="Bahnschrift SemiBold" FontSize="15" Foreground="White" />
          <TextBlock Text="{Binding Subtitle}" Margin="0,4,0,0" FontSize="12" Foreground="#D8E3F0" TextWrapping="Wrap" />
        </StackPanel>
      </DataTemplate>
      <DataTemplate x:Key="MetricCardTemplate">
        <Border Style="{StaticResource CardBorderStyle}" Width="220" Margin="0,0,16,16">
          <StackPanel>
            <TextBlock Text="{Binding Title}" Foreground="{StaticResource MutedInkBrush}" FontSize="12" />
            <TextBlock Text="{Binding Value}" Margin="0,8,0,4" FontFamily="Bahnschrift SemiBold" FontSize="28" Foreground="{StaticResource InkBrush}" />
            <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </DataTemplate>
    </ResourceDictionary>
  </UserControl.Resources>
  <Grid Background="{StaticResource CanvasBrush}">
    <Grid.ColumnDefinitions><ColumnDefinition Width="260" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
    <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" CornerRadius="0,24,24,0" Padding="20">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
          <TextBlock Text="NEWDIALER" FontFamily="Bahnschrift SemiBold" FontSize="26" Foreground="White" />
          <TextBlock Text="Outbound operations center" Margin="0,6,0,18" Foreground="#C4D2E0" FontSize="13" />
          <Border Background="{StaticResource AccentBrush}" CornerRadius="14" Padding="12">
            <StackPanel>
              <TextBlock Text="{Binding TenantName}" Foreground="White" FontWeight="SemiBold" />
              <TextBlock Text="{Binding ProductTagline}" Margin="0,4,0,0" Foreground="#D7FFF7" FontSize="12" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>
        <StackPanel DockPanel.Dock="Bottom">
          <TextBlock Text="Role-safe desktop shell" Foreground="#D8E3F0" FontSize="12" />
          <TextBlock Text="Lead copy is disabled in queue tables for agent views." Margin="0,4,0,0" Foreground="#AFC0D2" FontSize="12" TextWrapping="Wrap" />
        </StackPanel>
        <ListBox ItemsSource="{Binding NavigationItems}" SelectedItem="{Binding SelectedNavigation}" ItemTemplate="{StaticResource NavItemTemplate}" Style="{StaticResource SidebarListBoxStyle}" ItemContainerStyle="{StaticResource SidebarListBoxItemStyle}" />
      </DockPanel>
    </Border>
    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="24">
        <Grid Margin="0,0,0,20">
          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="340" /></Grid.ColumnDefinitions>
          <StackPanel>
            <TextBlock Text="{Binding CurrentUserName}" FontFamily="Bahnschrift SemiBold" FontSize="30" Foreground="{StaticResource InkBrush}" />
            <TextBlock Text="{Binding RoleHeadline}" Margin="0,6,0,0" Foreground="{StaticResource MutedInkBrush}" FontSize="14" />
          </StackPanel>
          <StackPanel Grid.Column="1" HorizontalAlignment="Right">
            <TextBlock Text="{Binding WorkspaceKeyDisplay}" HorizontalAlignment="Right" Foreground="{StaticResource MutedInkBrush}" FontSize="12" />
            <WrapPanel Margin="0,10,0,0" HorizontalAlignment="Right">
              <Button Content="Refresh" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RefreshWorkspaceCommand}" />
              <Button Content="Sign Out" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding SignOutCommand}" />
            </WrapPanel>
          </StackPanel>
        </Grid>
        <Border Style="{StaticResource CardBorderStyle}" Background="#FFF0FDF9" BorderBrush="#FFBAE6D6" Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}">
          <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" />
        </Border>
        <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFF1F2" BorderBrush="#FFFECACA" Visibility="{Binding HasErrorMessage, Converter={StaticResource BoolToVis}}">
          <TextBlock Text="{Binding ErrorMessage}" Foreground="#FFB42318" TextWrapping="Wrap" />
        </Border>
        <Border Style="{StaticResource CardBorderStyle}" BorderThickness="0" Padding="0">
          <Border CornerRadius="24" Padding="24">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF10253C" Offset="0" />
                <GradientStop Color="#FF0F766E" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="220" /></Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{Binding RoleLabel}" Foreground="#FFBEE7E2" FontSize="12" FontWeight="SemiBold" />
                <TextBlock Text="Production-grade desktop dialing foundation" Margin="0,8,0,0" Foreground="White" FontFamily="Bahnschrift SemiBold" FontSize="26" TextWrapping="Wrap" />
                <TextBlock Text="{Binding SubscriptionSummary}" Margin="0,10,0,0" Foreground="#D7FFF7" FontSize="14" TextWrapping="Wrap" />
              </StackPanel>
              <Border Grid.Column="1" Background="#1FFFFFFF" CornerRadius="18" Padding="16">
                <StackPanel>
                  <TextBlock Text="Queue" Foreground="#D7FFF7" FontSize="12" />
                  <TextBlock Text="{Binding QueueSummary}" Margin="0,8,0,0" Foreground="White" FontFamily="Bahnschrift SemiBold" FontSize="24" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </Grid>
          </Border>
        </Border>
        <StackPanel Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibilityConverter}, ConverterParameter=Dashboard}">
          <ItemsControl ItemsSource="{Binding DashboardCards}" ItemTemplate="{StaticResource MetricCardTemplate}">
            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
          </ItemsControl>
          <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
              <TextBlock Text="Architecture Direction" FontFamily="Bahnschrift SemiBold" FontSize="22" Foreground="{StaticResource InkBrush}" />
              <TextBlock Text="Keep the desktop app fast for agents, and keep subscriptions, security, reporting, and tenant isolation inside the backend API and PostgreSQL." Margin="0,12,0,0" Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>
        <StackPanel Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibilityConverter}, ConverterParameter=Dialer}">
          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="1.15*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,16">
              <StackPanel>
                <TextBlock Text="Dialer Console" FontFamily="Bahnschrift SemiBold" FontSize="24" Foreground="{StaticResource InkBrush}" />
                <TextBlock Text="{Binding DialerStatusText}" Margin="0,8,0,0" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                <TextBlock Text="Zoom Workplace is controlled locally from this PC. Start Dialer launches the registered Zoom phone protocol, and Hang Up sends Zoom&apos;s default End current call shortcut. For fully automatic dialing, enable Zoom&apos;s Automatically Call From 3rd Party Apps setting and approve user consent in Zoom." Margin="0,10,0,0" Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" />
                <Grid Margin="0,18,0,0">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="150" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                  <Grid.RowDefinitions><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /></Grid.RowDefinitions>
                  <TextBlock Text="Name" Foreground="{StaticResource MutedInkBrush}" /><TextBlock Grid.Column="1" Text="{Binding CurrentLeadName}" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
                  <TextBlock Grid.Row="1" Text="Email" Foreground="{StaticResource MutedInkBrush}" Margin="0,10,0,0" /><TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Text="{Binding CurrentLeadEmail}" Foreground="{StaticResource InkBrush}" />
                  <TextBlock Grid.Row="2" Text="Phone" Foreground="{StaticResource MutedInkBrush}" Margin="0,10,0,0" /><TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Text="{Binding CurrentLeadPhoneNumber}" Foreground="{StaticResource InkBrush}" />
                  <TextBlock Grid.Row="3" Text="Website" Foreground="{StaticResource MutedInkBrush}" Margin="0,10,0,0" /><TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Text="{Binding CurrentLeadWebsite}" Foreground="{StaticResource InkBrush}" />
                  <TextBlock Grid.Row="4" Text="Service" Foreground="{StaticResource MutedInkBrush}" Margin="0,10,0,0" /><TextBlock Grid.Row="4" Grid.Column="1" Margin="0,10,0,0" Text="{Binding CurrentLeadService}" Foreground="{StaticResource InkBrush}" />
                  <TextBlock Grid.Row="5" Text="Budget" Foreground="{StaticResource MutedInkBrush}" Margin="0,10,0,0" /><TextBlock Grid.Row="5" Grid.Column="1" Margin="0,10,0,0" Text="{Binding CurrentLeadBudget}" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
                </Grid>
                <WrapPanel Margin="0,24,0,0">
                  <Button Content="Start Dialer" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding StartDialerCommand}" IsEnabled="{Binding CanStart}" />
                  <Button Content="Hang Up" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding HangUpCommand}" Visibility="{Binding CanHangUp, Converter={StaticResource BoolToVis}}" />
                  <Button Content="Pause" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding PauseDialerCommand}" Visibility="{Binding CanPause, Converter={StaticResource BoolToVis}}" />
                  <Button Content="Resume" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ResumeDialerCommand}" Visibility="{Binding CanResume, Converter={StaticResource BoolToVis}}" />
                  <Button Content="Stop" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding StopDialerCommand}" IsEnabled="{Binding CanStop}" />
                  <Button Content="Schedule Call" Style="{StaticResource SecondaryButtonStyle}" Click="ScheduleLead_Click" IsEnabled="{Binding CanCreateSchedule}" />
                </WrapPanel>
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
              <StackPanel>
                <TextBlock Text="Active Queue" FontFamily="Bahnschrift SemiBold" FontSize="24" Foreground="{StaticResource InkBrush}" />
                <TextBlock Text="Clipboard copy is disabled for safer agent operation." Margin="0,8,0,18" Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" />
                <DataGrid ItemsSource="{Binding LeadQueue}" SelectedItem="{Binding SelectedLead}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False" IsReadOnly="True" ClipboardCopyMode="None" RowHeaderWidth="0">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="*" />
                    <DataGridTextColumn Header="Service" Binding="{Binding Service}" Width="*" />
                    <DataGridTextColumn Header="Budget" Binding="{Binding Budget}" Width="110" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="130" />
                  </DataGrid.Columns>
                </DataGrid>
              </StackPanel>
            </Border>
          </Grid>
        </StackPanel>
        <StackPanel Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibilityConverter}, ConverterParameter=Schedule}">
          <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
              <TextBlock Text="Scheduled Calls" FontFamily="Bahnschrift SemiBold" FontSize="24" Foreground="{StaticResource InkBrush}" />
              <TextBlock Text="Callbacks are persisted in PostgreSQL and can be started individually from this list." Margin="0,8,0,18" Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" />
              <WrapPanel Margin="0,0,0,14">
                <Button Content="Start Selected Callback" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding StartScheduledCallCommand}" />
              </WrapPanel>
              <DataGrid ItemsSource="{Binding ScheduledCalls}" SelectedItem="{Binding SelectedScheduledCall}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False" IsReadOnly="True" ClipboardCopyMode="None" RowHeaderWidth="0">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Lead" Binding="{Binding LeadName}" Width="*" />
                  <DataGridTextColumn Header="Agent" Binding="{Binding AgentName}" Width="140" />
                  <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="160" />
                  <DataGridTextColumn Header="When" Binding="{Binding LocalDisplay}" Width="170" />
                  <DataGridTextColumn Header="Time Zone" Binding="{Binding TimeZoneId}" Width="180" />
                  <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" />
                  <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="2*" />
                </DataGrid.Columns>
              </DataGrid>
            </StackPanel>
          </Border>
        </StackPanel>
        <StackPanel Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibilityConverter}, ConverterParameter=Leads}">
          <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
              <TextBlock Text="Lead Operations" FontFamily="Bahnschrift SemiBold" FontSize="24" Foreground="{StaticResource InkBrush}" />
              <TextBlock Text="Upload Excel files, auto-assign imported leads, and manually assign selected rows to agents from the desktop." Margin="0,8,0,18" Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" />
              <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="1.05*" />
                  <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{StaticResource AccentSoftBrush}" CornerRadius="18" Padding="16" Margin="0,0,16,0">
                  <StackPanel>
                    <TextBlock Text="Excel Import" FontFamily="Bahnschrift SemiBold" FontSize="20" Foreground="{StaticResource InkBrush}" />
                    <TextBlock Text="Choose an `.xlsx` lead file and optionally assign every imported lead to a default agent." Margin="0,8,0,14" Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" />
                    <TextBlock Text="Default Agent" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
                    <ComboBox Margin="0,8,0,12" Padding="10,6" ItemsSource="{Binding AgentOptions}" SelectedItem="{Binding SelectedImportAgent}" DisplayMemberPath="FullName" />
                    <TextBlock Text="Import Notes" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
                    <TextBox Margin="0,8,0,14" Height="72" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Text="{Binding ImportNotes, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Import Leads From Excel" Style="{StaticResource PrimaryButtonStyle}" Click="ImportLeads_Click" IsEnabled="{Binding CanManageLeads}" />
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#FFF8FAFC" CornerRadius="18" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Lead Assignment" FontFamily="Bahnschrift SemiBold" FontSize="20" Foreground="{StaticResource InkBrush}" />
                    <TextBlock Text="Select one or more leads from the table below, choose an agent, and assign them instantly." Margin="0,8,0,14" Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" />
                    <TextBlock Text="Assign To" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
                    <ComboBox Margin="0,8,0,14" Padding="10,6" ItemsSource="{Binding AgentOptions}" SelectedItem="{Binding SelectedAssignmentAgent}" DisplayMemberPath="FullName" />
                    <WrapPanel>
                      <Button Content="Assign Selected Leads" Style="{StaticResource SecondaryButtonStyle}" Click="AssignSelectedLeads_Click" IsEnabled="{Binding CanManageLeads}" />
                      <Button Content="Select All Visible" Style="{StaticResource SecondaryButtonStyle}" Click="SelectAllLeads_Click" IsEnabled="{Binding CanManageLeads}" />
                      <Button Content="Clear Selection" Style="{StaticResource SecondaryButtonStyle}" Click="ClearLeadSelection_Click" IsEnabled="{Binding CanManageLeads}" />
                    </WrapPanel>
                    <TextBlock Text="Tip: use Select All Visible or Ctrl/Shift-click rows to assign multiple leads at once." Margin="0,12,0,0" Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </Grid>
              <DataGrid x:Name="AdminLeadsGrid" ItemsSource="{Binding AdminAssignableLeads}" SelectedItem="{Binding SelectedLead}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False" IsReadOnly="True" ClipboardCopyMode="None" RowHeaderWidth="0" SelectionMode="Extended" SelectionUnit="FullRow">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                  <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" />
                  <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="160" />
                  <DataGridTextColumn Header="Website" Binding="{Binding Website}" Width="*" />
                  <DataGridTextColumn Header="Service" Binding="{Binding Service}" Width="160" />
                  <DataGridTextColumn Header="Budget" Binding="{Binding Budget}" Width="120" />
                  <DataGridTextColumn Header="Assigned Agent" Binding="{Binding AssignedAgentName}" Width="170" />
                  <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="140" />
                </DataGrid.Columns>
              </DataGrid>
              <TextBlock Text="Import Batches" Margin="0,20,0,12" FontFamily="Bahnschrift SemiBold" FontSize="20" Foreground="{StaticResource InkBrush}" />
              <DataGrid ItemsSource="{Binding ImportBatches}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False" IsReadOnly="True" RowHeaderWidth="0">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="2*" />
                  <DataGridTextColumn Header="Imported" Binding="{Binding ImportedRows}" Width="100" />
                  <DataGridTextColumn Header="Rows" Binding="{Binding TotalRows}" Width="100" />
                  <DataGridTextColumn Header="Imported At" Binding="{Binding ImportedAtUtc}" Width="180" />
                  <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="2*" />
                </DataGrid.Columns>
              </DataGrid>
            </StackPanel>
          </Border>
        </StackPanel>
        <StackPanel Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibilityConverter}, ConverterParameter=Agents}">
          <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
              <TextBlock Text="Agent Administration" FontFamily="Bahnschrift SemiBold" FontSize="24" Foreground="{StaticResource InkBrush}" />
              <TextBlock Text="{Binding AgentAnalyticsMessage}" Margin="0,8,0,18" Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" />
              <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="1.05*" />
                  <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{StaticResource AccentSoftBrush}" CornerRadius="18" Padding="16" Margin="0,0,16,0">
                  <StackPanel>
                    <TextBlock Text="{Binding AgentFormTitle}" FontFamily="Bahnschrift SemiBold" FontSize="20" Foreground="{StaticResource InkBrush}" />
                    <TextBlock Text="{Binding AgentFormDescription}" Margin="0,8,0,14" Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" />
                    <TextBlock Text="Agent Name" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
                    <TextBox Margin="0,8,0,12" Padding="12,10" Text="{Binding AgentFormFullName, UpdateSourceTrigger=PropertyChanged}" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1" />
                    <TextBlock Text="Agent Email" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
                    <TextBox Margin="0,8,0,12" Padding="12,10" Text="{Binding AgentFormEmail, UpdateSourceTrigger=PropertyChanged}" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1" />
                    <TextBlock Text="Password" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
                    <PasswordBox x:Name="AgentPasswordBox" Margin="0,8,0,6" Padding="12,10" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1" PasswordChanged="AgentPasswordBox_OnPasswordChanged" />
                    <TextBlock Text="Leave password blank while editing to keep the current password." Foreground="{StaticResource MutedInkBrush}" FontSize="12" TextWrapping="Wrap" />
                    <WrapPanel Margin="0,16,0,0">
                      <Button Content="{Binding AgentPrimaryButtonText}" Style="{StaticResource PrimaryButtonStyle}" Click="SaveAgent_Click" IsEnabled="{Binding CanSaveAgent}" />
                      <Button Content="Clear Form" Style="{StaticResource SecondaryButtonStyle}" Click="ClearAgentForm_Click" IsEnabled="{Binding CanManageAgents}" />
                      <Button Content="Delete Agent" Style="{StaticResource SecondaryButtonStyle}" Click="DeleteSelectedAgent_Click" IsEnabled="{Binding CanDeleteSelectedAgent}" />
                    </WrapPanel>
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#FFF8FAFC" CornerRadius="18" Padding="16">
                  <StackPanel>
                    <TextBlock Text="Selected Agent Snapshot" FontFamily="Bahnschrift SemiBold" FontSize="20" Foreground="{StaticResource InkBrush}" />
                    <TextBlock Text="Select an agent from the table below to review their live staffing data and update their profile." Margin="0,8,0,18" Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" />
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>
                      <TextBlock Text="Name" Foreground="{StaticResource MutedInkBrush}" />
                      <TextBlock Grid.Column="1" Text="{Binding SelectedAgentNameDisplay}" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
                      <TextBlock Grid.Row="1" Text="Email" Margin="0,10,0,0" Foreground="{StaticResource MutedInkBrush}" />
                      <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Text="{Binding SelectedAgentEmailDisplay}" Foreground="{StaticResource InkBrush}" />
                      <TextBlock Grid.Row="2" Text="Username" Margin="0,10,0,0" Foreground="{StaticResource MutedInkBrush}" />
                      <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Text="{Binding SelectedAgentUsernameDisplay}" Foreground="{StaticResource InkBrush}" />
                      <TextBlock Grid.Row="3" Text="Calls Today" Margin="0,10,0,0" Foreground="{StaticResource MutedInkBrush}" />
                      <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Text="{Binding SelectedAgentCallsTodayDisplay}" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
                      <TextBlock Grid.Row="4" Text="Scheduled Calls" Margin="0,10,0,0" Foreground="{StaticResource MutedInkBrush}" />
                      <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,10,0,0" Text="{Binding SelectedAgentScheduledCallsDisplay}" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
                      <TextBlock Grid.Row="5" Text="Talk Time" Margin="0,10,0,0" Foreground="{StaticResource MutedInkBrush}" />
                      <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,10,0,0" Text="{Binding SelectedAgentTalkTimeDisplay}" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" />
                      <TextBlock Grid.Row="6" Text="Check In" Margin="0,10,0,0" Foreground="{StaticResource MutedInkBrush}" />
                      <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,10,0,0" Text="{Binding SelectedAgentCheckInDisplay}" Foreground="{StaticResource InkBrush}" />
                      <TextBlock Grid.Row="7" Text="Check Out" Margin="0,10,0,0" Foreground="{StaticResource MutedInkBrush}" />
                      <TextBlock Grid.Row="7" Grid.Column="1" Margin="0,10,0,0" Text="{Binding SelectedAgentCheckOutDisplay}" Foreground="{StaticResource InkBrush}" />
                    </Grid>
                  </StackPanel>
                </Border>
              </Grid>
              <TextBlock Text="Active Agents" Margin="0,0,0,12" FontFamily="Bahnschrift SemiBold" FontSize="20" Foreground="{StaticResource InkBrush}" />
              <DataGrid x:Name="AgentsGrid" ItemsSource="{Binding Agents}" SelectedItem="{Binding SelectedAgent}" SelectionChanged="AgentsGrid_OnSelectionChanged" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False" IsReadOnly="True" RowHeaderWidth="0">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Agent" Binding="{Binding FullName}" Width="*" />
                  <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" />
                  <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="140" />
                  <DataGridTextColumn Header="Calls Today" Binding="{Binding CallsToday}" Width="120" />
                  <DataGridTextColumn Header="Scheduled Calls" Binding="{Binding ScheduledCalls}" Width="140" />
                  <DataGridTextColumn Header="Talk Time" Binding="{Binding TalkTime}" Width="140" />
                  <DataGridTextColumn Header="Check In" Binding="{Binding CheckIn}" Width="120" />
                  <DataGridTextColumn Header="Check Out" Binding="{Binding CheckOut}" Width="120" />
                </DataGrid.Columns>
              </DataGrid>
              <TextBlock Text="Assigned Lead Sheet" Margin="0,18,0,8" FontFamily="Bahnschrift SemiBold" FontSize="20" Foreground="{StaticResource InkBrush}" />
              <TextBlock Text="{Binding SelectedAgentLeadSheetSummary}" Margin="0,0,0,12" Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" />
              <DataGrid ItemsSource="{Binding SelectedAgentLeads}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False" IsReadOnly="True" RowHeaderWidth="0" ClipboardCopyMode="None">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                  <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" />
                  <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="160" />
                  <DataGridTextColumn Header="Website" Binding="{Binding Website}" Width="*" />
                  <DataGridTextColumn Header="Service" Binding="{Binding Service}" Width="160" />
                  <DataGridTextColumn Header="Budget" Binding="{Binding Budget}" Width="120" />
                  <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="130" />
                </DataGrid.Columns>
              </DataGrid>
            </StackPanel>
          </Border>
        </StackPanel>
        <StackPanel Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibilityConverter}, ConverterParameter=Billing}">
          <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
              <TextBlock Text="Subscription State" FontFamily="Bahnschrift SemiBold" FontSize="24" Foreground="{StaticResource InkBrush}" />
              <TextBlock Text="{Binding SubscriptionSummary}" Margin="0,10,0,0" Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" />
              <TextBlock Text="After the trial ends, users can stay in read-only mode until your team manually activates or renews access." Margin="0,12,0,0" Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>
        <StackPanel Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibilityConverter}, ConverterParameter=Developer}">
          <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
              <TextBlock Text="Developer Panel" FontFamily="Bahnschrift SemiBold" FontSize="24" Foreground="{StaticResource InkBrush}" />
              <TextBlock Text="Your internal team can monitor tenant trials, active subscriptions, and renewals here." Margin="0,8,0,18" Foreground="{StaticResource MutedInkBrush}" TextWrapping="Wrap" />
              <DataGrid ItemsSource="{Binding DeveloperTenants}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False" IsReadOnly="True" RowHeaderWidth="0">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Company" Binding="{Binding CompanyName}" Width="*" />
                  <DataGridTextColumn Header="Admin Email" Binding="{Binding AdminEmail}" Width="*" />
                  <DataGridTextColumn Header="Plan" Binding="{Binding Plan}" Width="120" />
                  <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" />
                  <DataGridTextColumn Header="Trial Ends" Binding="{Binding TrialEnds}" Width="130" />
                  <DataGridTextColumn Header="Current Period Ends" Binding="{Binding CurrentPeriodEnds}" Width="150" />
                </DataGrid.Columns>
              </DataGrid>
            </StackPanel>
          </Border>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
